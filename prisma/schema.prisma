generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum UnitSystem {
    imperial
    metric
}

model User {
    id                 Int                 @id() @default(autoincrement())
    providerId         String              @unique
    login              String              @unique
    displayName        String              @unique
    createdAt          DateTime            @default(now())
    updatedAt          DateTime            @updatedAt
    balances           Balance[]
    Player             Player[]
    Fish               Fish[]
    UserStats          UserStats[]
    FishStats          FishStats[]
    DuelChallenger     Duel[]              @relation("Challenger")
    DuelChallenged     Duel[]              @relation("Challenged")
    unitSystem         UnitSystem          @default(metric)
    FishDexEntry       FishDexEntry[]
    FishDexCompletion  FishDexCompletion[]
    ChatMailsSender    ChatMail[]          @relation("Sender")
    ChatMailsRecipient ChatMail[]          @relation("Recipient")
}

model Balance {
    id                Int      @id() @default(autoincrement())
    channel           String
    channelProviderId String
    value             BigInt   @default(500)
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
    user              User     @relation(fields: [userId], references: [providerId], onDelete: Cascade, onUpdate: Cascade)
    userId            String

    @@unique([channelProviderId, userId])
}

model Player {
    id          Int       @id() @default(autoincrement())
    user        User      @relation(fields: [userId], references: [providerId], onDelete: Cascade, onUpdate: Cascade)
    userId      String
    buyin       BigInt    @default(0)
    adventure   Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    adventureId Int
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
}

model Adventure {
    id                Int      @id @default(autoincrement())
    name              String
    channel           String
    channelProviderId String
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
    players           Player[]
    payoutRate        Float    @default(1.3)

    @@index([channelProviderId])
}

enum Rarity {
    Trash
    Common
    Uncommon
    Fine
    Rare
    Epic
    Mythic
    Exotic
    Legendary
}

enum FishQuality {
    Normal
    Shining
    Glistening
    Opulent
    Radiant
    Alpha
}

model Fish {
    id                Int          @id @default(autoincrement())
    channelProviderId String
    channel           String
    user              User         @relation(fields: [userId], references: [providerId], onDelete: Cascade, onUpdate: Cascade)
    userId            String
    createdAt         DateTime     @default(now())
    updatedAt         DateTime     @updatedAt
    name              String
    size              String
    weight            String
    rarity            Rarity
    quality           FishQuality  @default(Normal)
    value             Int
    prefix            String
    fishId            String
    emote             String?
    LargestRecord     FishRecord[] @relation("LargestFish")
    SmallestRecord    FishRecord[] @relation("SmallestFish")
    HeaviestRecord    FishRecord[] @relation("HeaviestFish")
    LightestRecord    FishRecord[] @relation("LightestFish")

    @@unique([channelProviderId, fishId])
    @@index([channelProviderId, userId])
}

model ChannelFishCount {
    channelProviderId String   @id
    total             BigInt   @default(0)
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
}

model UserStats {
    id                Int      @id @default(autoincrement())
    user              User     @relation(fields: [userId], references: [providerId], onDelete: Cascade, onUpdate: Cascade)
    userId            String
    channelProviderId String
    channel           String
    // General game stats (example, adjust as needed)
    gamesPlayed       Int      @default(0)
    gamesWon          Int      @default(0)
    totalWagers       BigInt   @default(0) // Consider if this should include duel wagers or be separate
    totalWinnings     BigInt   @default(0) // Consider if this should include duel winnings or be separate
    // Duel specific stats
    duelsPlayed       Int      @default(0)
    duelsWon          Int      @default(0)
    duelsWagered      BigInt   @default(0)
    duelsWonAmount    BigInt   @default(0)
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt

    fishFines Int @default(0) // Total fines for fish caught

    winStreak  Int @default(0)
    loseStreak Int @default(0)

    duelWinStreak  Int @default(0)
    duelLoseStreak Int @default(0)

    streakWager Int @default(0) // Sum of wagers during current win/lose streak

    // RPS specific stats
    rpsPlayed     Int    @default(0)
    rpsWon        Int    @default(0)
    rpsWagered    BigInt @default(0)
    rpsWonAmount  BigInt @default(0)
    rpsWinStreak  Int    @default(0)
    rpsLoseStreak Int    @default(0)

    @@unique([channelProviderId, userId])
    @@index([channelProviderId, userId])
}

model FishStats {
    id                      Int      @id @default(autoincrement())
    user                    User     @relation(fields: [userId], references: [providerId], onDelete: Cascade, onUpdate: Cascade)
    userId                  String
    channelProviderId       String
    channel                 String
    xp                      BigInt   @default(0)
    fishingRodLevel         Int      @default(0)
    activeRodLevel          Int      @default(0)
    hasNotifiedUpgrade      Boolean  @default(false)
    hasNotifiedEnoughSilver Boolean  @default(false)
    trashFishCount          Int      @default(0)
    commonFishCount         Int      @default(0)
    uncommonFishCount       Int      @default(0)
    fineFishCount           Int      @default(0)
    rareFishCount           Int      @default(0)
    epicFishCount           Int      @default(0)
    exoticFishCount         Int      @default(0)
    mythicFishCount         Int      @default(0)
    legendaryFishCount      Int      @default(0)
    fishFines               Int      @default(0)
    fishFinesCount          Int      @default(0)
    treasureSilver          Int      @default(0)
    treasureCount           Int      @default(0)
    totalSilverWorth        Int      @default(0)
    createdAt               DateTime @default(now())
    updatedAt               DateTime @updatedAt

    @@unique([channelProviderId, userId])
    @@index([channelProviderId, userId])
}

model FishRecord {
    id                Int         @id @default(autoincrement())
    channelProviderId String
    channel           String
    fishName          String
    quality           FishQuality @default(Normal)
    largestFish       Fish        @relation("LargestFish", fields: [largestFishId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    smallestFish      Fish        @relation("SmallestFish", fields: [smallestFishId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    heaviestFish      Fish        @relation("HeaviestFish", fields: [heaviestFishId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    lightestFish      Fish        @relation("LightestFish", fields: [lightestFishId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    largestFishId     Int
    smallestFishId    Int
    heaviestFishId    Int
    lightestFishId    Int
    updatedAt         DateTime    @updatedAt
    createdAt         DateTime    @default(now())

    @@unique([channelProviderId, fishName, quality])
    @@index([channelProviderId])
}

model Duel {
    id                Int        @id @default(autoincrement())
    challenger        User       @relation("Challenger", fields: [challengerId], references: [providerId], onDelete: Cascade, onUpdate: Cascade)
    challengerId      String
    challenged        User       @relation("Challenged", fields: [challengedId], references: [providerId], onDelete: Cascade, onUpdate: Cascade)
    challengedId      String
    channelProviderId String
    channel           String
    wagerAmount       BigInt
    status            DuelStatus @default(Pending)
    createdAt         DateTime   @default(now())
    updatedAt         DateTime   @updatedAt

    @@index([channelProviderId, challengerId, challengedId])
}

model EmoteUsage {
    id                Int      @id @default(autoincrement())
    channelProviderId String
    emoteName         String
    usageCount        Int      @default(0)
    updatedAt         DateTime @updatedAt
    createdAt         DateTime @default(now())

    @@unique([channelProviderId, emoteName])
    @@index([channelProviderId, emoteName])
}

enum EmoteProvider {
    Twitch
    BTTV
    FFZ
    SevenTV
}

model EmoteUsageEvent {
    id                Int      @id @default(autoincrement())
    channelProviderId String
    emoteName         String
    userId            String   @default("")
    usedAt            DateTime @default(now())

    @@index([channelProviderId, emoteName, usedAt])
}

model EmoteUsageEventV2 {
    id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    channelProviderId String
    emoteName         String
    userId            String
    usedAt            DateTime       @default(now()) @db.Timestamptz()
    provider          EmoteProvider?
    emoteId           String?

    @@index([channelProviderId, emoteName, usedAt])
}

model FishDexEntry {
    id                Int      @id @default(autoincrement())
    user              User     @relation(fields: [userId], references: [providerId], onDelete: Cascade, onUpdate: Cascade)
    userId            String
    channelProviderId String
    fishName          String
    rarity            Rarity
    firstCaughtAt     DateTime @default(now())

    @@unique([channelProviderId, userId, fishName])
    @@index([channelProviderId, userId, rarity, fishName])
    @@map("FishDex")
}

model FishDexCompletion {
    id                Int      @id @default(autoincrement())
    user              User     @relation(fields: [userId], references: [providerId], onDelete: Cascade, onUpdate: Cascade)
    userId            String
    channelProviderId String
    rarity            Rarity
    completedAt       DateTime @default(now())
    reward            Int

    @@unique([channelProviderId, userId, rarity])
    @@index([channelProviderId, userId, rarity])
}

model LegendaryEvent {
    id              Int      @id @default(autoincrement())
    name            String
    legendaryWeight Int
    message         String?
    startedAt       DateTime @default(now())
    endsAt          DateTime
    active          Boolean  @default(true)
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    @@index([active])
}

enum DuelStatus {
    Pending
    Accepted
    Declined
    Completed
}

model Match {
    id          BigInt      @id @default(autoincrement())
    channel     String
    playerA     String
    playerB     String
    wager       Int
    status      MatchStatus @default(ACTIVE)
    winner      String?
    createdAt   DateTime    @default(now())
    completedAt DateTime?

    rounds Round[]

    @@index([playerA])
    @@index([playerB])
    @@index([status])
}

model Round {
    id        BigInt       @id @default(autoincrement())
    matchId   BigInt
    roundNum  Int
    winner    RoundWinner?
    createdAt DateTime     @default(now())

    match Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
    moves Move[]

    @@unique([matchId, roundNum])
}

model Move {
    id        BigInt   @id @default(autoincrement())
    roundId   BigInt
    player    String
    move      RpsMove
    createdAt DateTime @default(now())

    round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

    @@unique([roundId, player])
}

enum MatchStatus {
    ACTIVE
    COMPLETE
    CANCELLED
}

enum RoundWinner {
    PLAYER_A
    PLAYER_B
    DRAW
}

enum RpsMove {
    ROCK
    PAPER
    SCISSORS
}

model ChatMail {
    id          BigInt    @id @default(autoincrement())
    mailCode    String    @unique @default(nanoid(8))
    sender      User      @relation("Sender", fields: [senderId], references: [providerId], onDelete: Cascade, onUpdate: Cascade)
    senderId    String
    recipient   User      @relation("Recipient", fields: [recipientId], references: [providerId], onDelete: Cascade, onUpdate: Cascade)
    recipientId String
    channelId   String
    content     String
    createdAt   DateTime  @default(now())
    deliveredAt DateTime?
    expiresAt   DateTime?
}
